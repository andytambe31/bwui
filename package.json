{
  "name": "@andytambe31/bwui",
  "version": "0.1.0-alpha.1",
  "description": "bwui (pronounced as buoy) is a lightweight CSS framework for building functional user interfaces with minimal configuration.",
  "scripts": {
    "build": "sass src/bwui.scss dist/bwui.css",
    "build:min": "sass src/bwui.scss dist/bwui.min.css --style=compressed",
    "format": "prettier --write .",
    "lint:css": "stylelint \"src/**/*.scss\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andytambe31/bwui.git"
  },
  "keywords": [
    "css",
    "scss",
    "sass",
    "framework",
    "ui",
    "frontend",
    "bwui"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Aniruddha Tambe",
  "license": "MIT",
  "style": "dist/bwui.css",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "bugs": {
    "url": "https://github.com/andytambe31/bwui/issues"
  },
  "homepage": "https://github.com/andytambe31/bwui#readme",
  "devDependencies": {
    "modern-normalize": "^3.0.1",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "@andytambe31/bwui": "^0.1.0-alpha.0"
  }
}
